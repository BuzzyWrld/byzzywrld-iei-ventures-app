# Copy to .env.local and fill in as needed.
# Nothing required to run with the stub adapter.

# --- Skill execution ---
# SKILL_ADAPTER=stub|agent-sdk|subprocess   (default: stub)
#   stub       — no API cost; generates placeholder outputs
#   agent-sdk  — runs Buzz's real brand-playbook skill via Claude
#   subprocess — external CLI-based skill (unused today)
# SKILL_ADAPTER=stub

# --- Claude (required when SKILL_ADAPTER=agent-sdk) ---
# ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-haiku-4-5     # cheap + capable, ~$0.30/brand
# CLAUDE_MODEL=claude-sonnet-4-6    # premium quality, ~$1/brand

# --- Vercel deploy (Day 4) ---
# VERCEL_TOKEN=
# VERCEL_TEAM_ID=
