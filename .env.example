# Copy to .env.local and fill in as needed.
# Nothing required to run with the stub adapter.

# --- Skill execution ---
# SKILL_ADAPTER=stub|agent-sdk|deepseek|kimi|subprocess   (default: stub)
#   stub       — no API cost; placeholder outputs
#   agent-sdk  — Claude via Agent SDK       ~$0.18/brand on Haiku
#   deepseek   — DeepSeek V3 via OpenAI API ~$0.05/brand
#   kimi       — Moonshot Kimi K2           ~$0.05-0.08/brand
#   subprocess — external CLI (unused today)
# SKILL_ADAPTER=stub

# --- Claude (when SKILL_ADAPTER=agent-sdk) ---
# ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-haiku-4-5
# CLAUDE_MODEL=claude-sonnet-4-6

# --- DeepSeek (when SKILL_ADAPTER=deepseek) ---
# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_MODEL=deepseek-chat      # V3 (default)
# DEEPSEEK_MODEL=deepseek-reasoner  # R1 reasoning model

# --- Moonshot / Kimi (when SKILL_ADAPTER=kimi) ---
# KIMI_API_KEY=sk-...
# KIMI_MODEL=kimi-k2-0711-preview
# KIMI_BASE_URL=https://api.moonshot.ai/v1  # or https://api.moonshot.cn/v1 for CN

# --- Vercel deploy (Day 4) ---
# VERCEL_TOKEN=
# VERCEL_TEAM_ID=
